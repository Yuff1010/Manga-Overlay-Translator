# 任何 OpenAI 兼容接口均可：DeepSeek / OpenAI / 各类中转 / 本地 Ollama
#
# 第一组用无后缀的变量名。只配这一组就够用，行为和以前完全一样。
LLM_NAME=DeepSeek
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-xxxx
LLM_MODEL=deepseek-chat
# 可选：面板下拉里为这个供应商列出的多个模型（逗号分隔，留空则只列 LLM_MODEL）
LLM_MODELS=deepseek-chat,deepseek-reasoner

# 想在面板上切换多个供应商，就再加几组，后缀从 2 开始递增。
# 没有的组直接删掉即可。
#LLM_2_NAME=OpenAI
#LLM_2_BASE_URL=https://api.openai.com/v1
#LLM_2_API_KEY=sk-yyyy
#LLM_2_MODELS=gpt-4o-mini,gpt-4o

#LLM_3_NAME=本地 Ollama
#LLM_3_BASE_URL=http://127.0.0.1:11434/v1
#LLM_3_API_KEY=ollama
#LLM_3_MODELS=qwen2.5:7b,gemma2:9b
